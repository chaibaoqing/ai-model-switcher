    "setup": "node scripts/setup-wizard.js",
    "install-service": "node scripts/install-service.js",
    "uninstall-service": "node scripts/uninstall-service.js",
    "tray": "node scripts/tray.js",
    "tray:cli": "node scripts/tray.js --cli"
  },
  "keywords": ["ai", "model-switcher", "codex", "deepseek", "zhipu", "glm", "proxy", "openai", "relay"],
